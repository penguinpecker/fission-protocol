# Hedera RPC endpoints (Hashio JSON-RPC relay)
HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
HEDERA_MAINNET_RPC=https://mainnet.hashio.io/api

# Deployer ECDSA private key (0x-prefixed, NOT DER encoded)
# Generate via: npx hardhat generate-key
DEPLOYER_PRIVATE_KEY=0x...

# Hedera account ID (optional, for mirror node queries)
DEPLOYER_ACCOUNT_ID=0.0.xxxxx

# SaucerSwap V2 contracts (mainnet)
SAUCERSWAP_ROUTER=0x...
SAUCERSWAP_HBAR_USDC_POOL=0x...

# Stader HBARX (mainnet)
HBARX_TOKEN=0x...
STADER_CONTRACT=0x...

# Bonzo Finance (mainnet)
BONZO_POOL=0x...
BONZO_BUSDC=0x...

# USDT0 on Hedera
USDT0_TOKEN=0x...
